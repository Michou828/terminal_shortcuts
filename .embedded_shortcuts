#Embeded Devices Tools
function ed_u() {    #pio run upload (-e env -p m/s+port -t target)
  local env=""
  local port_input=""
  local target="upload"
  local final_port=""
  local use_flags=false

  for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
      use_flags=true
      break
    fi
  done

  if $use_flags; then
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -e) env="$2"; shift 2;;
        -p) port_input="$2"; shift 2;;
        -t) target="$2"; shift 2;;
        *) shift;;
      esac
    done
  else
    # Backward-compatible positional args: ed_u <env> <port> <target>
    env="$1"
    port_input="$2"
    target="${3:-upload}"
  fi

  # Parse port: m101 -> usbmodem101, s101 -> usbserial101, 101 -> usbmodem101 (legacy)
  if [[ -n "$port_input" ]]; then
    if [[ "$port_input" == m* ]]; then
      final_port="usbmodem${port_input#m}"
    elif [[ "$port_input" == s* ]]; then
      final_port="usbserial${port_input#s}"
    elif [[ "$port_input" =~ ^[0-9]+$ ]]; then
      final_port="usbmodem$port_input"
    else
      final_port="$port_input"
    fi
  fi

  # If no env given, warn if platformio.ini has [env:*] sections
  if [[ -z "$env" ]]; then
    if grep -q "^\[env:" platformio.ini 2>/dev/null; then
      echo "⚠️  Warning: platformio.ini defines environments but no -e flag was given."
      echo -n "   Press Enter to continue without specifying an env, or Ctrl+C to cancel... "
      read
    fi
  fi

  # Build and run command
  local -a cmd=(pio run)
  [[ -n "$env" ]] && cmd+=(-e "$env")
  cmd+=(--target "$target")
  [[ -n "$final_port" ]] && cmd+=(--upload-port "/dev/cu.$final_port")
  "${cmd[@]}"
}


function ed_m() {    #pio monitor serial port (-p m/s+port -b baud)
  local port_input=""
  local baud=115200
  local final_port=""
  local use_flags=false

  for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
      use_flags=true
      break
    fi
  done

  if $use_flags; then
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -p) port_input="$2"; shift 2;;
        -b) baud="$2"; shift 2;;
        *) shift;;
      esac
    done
    if [[ -z "$port_input" ]]; then
      echo "❌ Error: -p <port> is required. Example: ed_m -p m101"
      return 1
    fi
  else
    # Backward-compatible positional args: ed_m <port> <baud>
    port_input="$1"
    baud="${2:-115200}"
  fi

  # Parse port: m101 -> usbmodem101, s101 -> usbserial101, 101 -> usbmodem101 (legacy)
  if [[ "$port_input" == m* ]]; then
    final_port="usbmodem${port_input#m}"
  elif [[ "$port_input" == s* ]]; then
    final_port="usbserial${port_input#s}"
  elif [[ "$port_input" =~ ^[0-9]+$ ]]; then
    final_port="usbmodem$port_input"
  else
    final_port="$port_input"
  fi

  pio device monitor --port /dev/cu."$final_port" --baud "$baud"
}


function ed_s() {    #screen serial port (-p m/s+port -b baud)
  local port_input=""
  local baud=115200
  local final_port=""
  local use_flags=false

  for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
      use_flags=true
      break
    fi
  done

  if $use_flags; then
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -p) port_input="$2"; shift 2;;
        -b) baud="$2"; shift 2;;
        *) shift;;
      esac
    done
    if [[ -z "$port_input" ]]; then
      echo "❌ Error: -p <port> is required. Example: ed_s -p m101"
      return 1
    fi
  else
    # Backward-compatible positional args: ed_s <port> <baud>
    port_input="$1"
    baud="${2:-115200}"
  fi

  # Parse port: m101 -> usbmodem101, s101 -> usbserial101, 101 -> usbmodem101 (legacy)
  if [[ "$port_input" == m* ]]; then
    final_port="usbmodem${port_input#m}"
  elif [[ "$port_input" == s* ]]; then
