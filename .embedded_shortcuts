function ed_ls() {    #list devices (cu and tty)
  echo "--- /dev/cu.* ---"
  ls /dev/cu.* 2>/dev/null
  echo "--- /dev/tty.* ---"
  ls /dev/tty.* 2>/dev/null
}


# Update terminal shortcuts from GitHub
function update_embedded_shortcuts() {    #update shortcuts from github
    echo "⬇️  Fetching latest shortcuts from GitHub..."

    # Adding ?v=$RANDOM forces GitHub to bypass its 5-minute cache
    SHORTCUT_URL="https://raw.githubusercontent.com/Michou828/terminal_shortcuts/main/.embedded_shortcuts?v=$RANDOM"
    DEST_FILE="$HOME/.embedded_shortcuts"

    if curl -fsSL "$SHORTCUT_URL" -o "$DEST_FILE"; then
        echo "♻️  Reloading shortcuts..."
        source "$DEST_FILE"
        echo "✅ Shortcuts updated successfully!"
    else
        echo "❌ Failed to update shortcuts. Check your internet connection."
    fi
}

function ls_edsc() {    #Show this help menu for embedded_shortcuts
    echo "========================================================="
    echo "             🛠️  Embedded Shortcuts Menu 🛠️"
    echo "========================================================="
    echo ""
    echo "📌 ALIASES:"
    # This removes the word 'alias', splits the line at '#', and aligns the text
    grep "^alias" "$HOME/.embedded_shortcuts" | sed 's/alias //' | awk -F'#' '{ printf "  %-15s ➜ %s\n", $1, $2 }'
    echo ""
    echo "⚙️  FUNCTIONS:"
    # This removes 'function' and '() {', splits at '#', and aligns the text
    grep "^function" "$HOME/.embedded_shortcuts" | sed 's/function //' | sed 's/() {//' | awk -F'#' '{ printf "  %-15s ➜ %s\n", $1, $2 }'
    echo "========================================================="
}
